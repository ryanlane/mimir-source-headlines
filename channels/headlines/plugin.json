{
  "id": "com.mimir.headlines",
  "name": "Headlines",
  "description": "Displays live news headlines from NewsAPI. Each configured feed targets a category, keyword, or country — assign different feeds to different screens.",
  "version": "1.2.0",
  "type": "embedded",
  "entry_point": "channel.py",
  "class_name": "HeadlinesChannel",
  "icon": "newspaper",
  "author": "Ryan Lane",
  "tags": [
    "news",
    "headlines",
    "live",
    "newsapi",
    "rss"
  ],
  "schemaVersion": "2.4",
  "settingsType": "advanced",
  "config": {
    "supports_upload": false,
    "supports_subchannels": true,
    "requires_api_key": true,
    "renders_locally": true
  },
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "fastapi",
      "pillow",
      "requests",
      "jinja2"
    ]
  },
  "user_data_dirs": [
    "data"
  ],
  "update_schedule": {
    "unit": "minutes",
    "duration": 60,
    "settings_driven": true,
    "settings_key": "cache_minutes"
  },
  "settings": {
    "defaults": {
      "api_key": "",
      "cache_minutes": 60
    },
    "schema": {
      "type": "object",
      "properties": {
        "api_key": {
          "type": "string",
          "title": "NewsAPI Key"
        },
        "cache_minutes": {
          "type": "integer",
          "minimum": 15,
          "maximum": 360,
          "title": "Cache Duration (minutes)",
          "description": "How long to cache headlines before re-fetching",
          "default": 60
        }
      }
    }
  },
  "endpoints": [
    { "path": "/manifest",              "method": "GET",    "description": "Channel manifest" },
    { "path": "/subchannels",           "method": "GET",    "description": "List configured feeds" },
    { "path": "/subchannels",           "method": "POST",   "description": "Create a new feed" },
    { "path": "/subchannels/{id}",      "method": "GET",    "description": "Get a feed config" },
    { "path": "/subchannels/{id}",      "method": "PUT",    "description": "Update a feed config" },
    { "path": "/subchannels/{id}",      "method": "DELETE", "description": "Delete a feed" },
    { "path": "/subchannels/{id}/preview", "method": "GET", "description": "Render a preview image" },
    { "path": "/preview",               "method": "POST",   "description": "Render a preview from an unsaved config" },
    { "path": "/request-image",         "method": "POST",   "description": "Render headline image at display resolution" },
    { "path": "/settings",              "method": "GET",    "description": "Get settings" },
    { "path": "/settings",              "method": "PUT",    "description": "Update settings" },
    { "path": "/status",                "method": "GET",    "description": "Health and cache status" },
    { "path": "/validate-key",          "method": "POST",   "description": "Validate a NewsAPI key" }
  ]
}
